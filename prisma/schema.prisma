generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @db.VarChar(255)
  users     User[]
}

model Company {
  company_id   Int          @id @default(autoincrement())
  name         String       @db.VarChar(255)
  description  String
  industry     String?      @db.VarChar(255)
  website      String?
  logo_url     String?
  location     String       @db.VarChar(255)
  company_size String?      @db.VarChar(50)
  founded_year Int?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  internships  Internship[]
  jobs         Job[]

  status Int @default(1)
}

model Job {
  job_id               Int           @id @default(autoincrement())
  company_id           Int
  title                String        @db.VarChar(255)
  description          String
  location             String        @db.VarChar(255)
  job_type             String?       @db.VarChar(50)
  salary_min           Int?
  salary_max           Int?
  experience_level     String?       @db.VarChar(50)
  application_deadline DateTime?
  apply_url            String?
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt
  applications         Application[]
  company              Company       @relation(fields: [company_id], references: [company_id])

  status Int @default(1)

  jobSkills  JobSkill[]
}

model Internship {
  internship_id        Int           @id @default(autoincrement())
  company_id           Int
  title                String        @db.VarChar(255)
  description          String
  location             String        @db.VarChar(255)
  stipend              Int?
  duration             String?
  internship_type      String?       @db.VarChar(50)
  start_date           DateTime?
  application_deadline DateTime?
  apply_url            String?
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt
  applications         Application[]
  company              Company       @relation(fields: [company_id], references: [company_id])

  status Int @default(1)

  internshipSkills InternshipSkill[]
}

model Course {
  course_id   Int                @id @default(autoincrement())
  title       String             @db.VarChar(255)
  description String
  provider    String?
  instructor  String?
  category    String?            @db.VarChar(100)
  level       String?            @db.VarChar(50)
  duration    String?
  course_url  String?
  price       Int?
  rating      Float?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  target_group String @default("college")

  status Int @default(1)

  enrollments CourseEnrollment[]
  courseSkills CourseSkill[]
  courseInterests CourseInterest[]
  savedCourses SavedCourse[]
}

model Hackathon {
  hackathon_id          Int                    @id @default(autoincrement())
  title                 String                 @db.VarChar(255)
  description           String
  organizer             String                 @db.VarChar(255)
  location              String                 @db.VarChar(255)
  start_date            DateTime
  end_date              DateTime
  registration_deadline DateTime?
  prize_pool            Int?
  mode                  String?                @db.VarChar(50)
  event_url             String?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  status Int @default(1)

  participants          HackathonParticipant[]
}

model User {
  user_id                 BigInt   @id @default(autoincrement())
  full_name               String   @db.VarChar(255)
  email                   String   @unique @db.VarChar(255)

  password_hash           String?
  auth_provider           String   @default("LOCAL")
  firebase_uid            String?  @unique

  phone                   String?  @db.VarChar(20)

  // 🎓 College fields
  university              String?  @db.VarChar(255)
  degree                  String?  @db.VarChar(255)
  graduation_year         Int?

  // 🏫 School support (NEW)
  class                   Int?
  school_name             String?  @db.VarChar(255)

  // 🎯 Optional user intent (NEW)
  goal                    String?  @db.VarChar(255)

  resume_url              String?
  linkedin_url            String?
  github_url              String?

  role_id                 Int      @default(4)

  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  age                     Int?
  about_me                String?
  address                 String?  @db.VarChar(255)

  status                  Int      @default(1)

  applications            Application[]
  courseEnrollments       CourseEnrollment[]
  hackathonParticipations HackathonParticipant[]
  role                    Role     @relation(fields: [role_id], references: [role_id])

  userSkills              UserSkill[]
  projects                Project[]
  certificates            Certificate[]

  devices                 UserDevice[]
  notifications           Notification[]

  // ⭐ NEW RELATIONS
  interests               UserInterest[]
  achievements            UserAchievement[]
  savedCourses SavedCourse[]
}

model CourseEnrollment {
  id                Int      @id @default(autoincrement())
  user_id           BigInt
  course_id         Int

  completion_status String?  @db.VarChar(50)

  // ⭐ NEW (REAL VALUE)
  progress          Int      @default(0)   // 0 → 100
  completed         Boolean  @default(false)

  enrollment_date   DateTime @default(now())

  course            Course   @relation(fields: [course_id], references: [course_id])
  user              User     @relation(fields: [user_id], references: [user_id])
}

model HackathonParticipant {
  id                Int       @id @default(autoincrement())
  user_id           BigInt
  hackathon_id      Int
  team_name         String?   @db.VarChar(255)
  registration_date DateTime  @default(now())
  hackathon         Hackathon @relation(fields: [hackathon_id], references: [hackathon_id])
  user              User      @relation(fields: [user_id], references: [user_id])
}

model Application {
  id            Int         @id @default(autoincrement())
  user_id       BigInt
  job_id        Int?
  internship_id Int?
  status        String?     @db.VarChar(50)
  applied_at    DateTime    @default(now())
  internship    Internship? @relation(fields: [internship_id], references: [internship_id])
  job           Job?        @relation(fields: [job_id], references: [job_id])
  user          User        @relation(fields: [user_id], references: [user_id])
}

model Skill {
  skill_id Int @id @default(autoincrement())
  name     String @unique

  userSkills UserSkill[]
  jobSkills  JobSkill[]
  internshipSkills InternshipSkill[]
  projectSkills ProjectSkill[]
  courseSkills CourseSkill[]
}

model UserSkill {
  id        Int @id @default(autoincrement())

  user_id   BigInt
  skill_id  Int

  proficiency Int

  user      User  @relation(fields: [user_id], references: [user_id])
  skill     Skill @relation(fields: [skill_id], references: [skill_id])

  @@unique([user_id, skill_id])
}

model JobSkill {
  id       Int @id @default(autoincrement())

  job_id   Int
  skill_id Int

  job      Job   @relation(fields: [job_id], references: [job_id])
  skill    Skill @relation(fields: [skill_id], references: [skill_id])

}

model InternshipSkill {
  id            Int @id @default(autoincrement())

  internship_id Int
  skill_id      Int

  internship    Internship @relation(fields: [internship_id], references: [internship_id])
  skill         Skill      @relation(fields: [skill_id], references: [skill_id])

}

model Certificate {
  certificate_id Int @id @default(autoincrement())

  user_id        BigInt

  title          String @db.VarChar(255)
  issuer         String @db.VarChar(255)
  issue_date     DateTime?

  file_url       String?  

  user           User @relation(fields: [user_id], references: [user_id])

  status Int @default(1)

  created_at     DateTime @default(now())
}

model Project {
  project_id   Int @id @default(autoincrement())

  user_id      BigInt

  title        String @db.VarChar(255)
  description  String

  user         User @relation(fields: [user_id], references: [user_id])

  status Int @default(1)

  projectSkills ProjectSkill[]

  created_at   DateTime @default(now())
}

model ProjectSkill {
  id         Int @id @default(autoincrement())

  project_id Int
  skill_id   Int?

  custom_skill String?

  project    Project @relation(fields: [project_id], references: [project_id])
  skill      Skill?  @relation(fields: [skill_id], references: [skill_id])

  @@unique([project_id, skill_id, custom_skill])
}

model CourseSkill {
  id        Int @id @default(autoincrement())

  course_id Int
  skill_id  Int

  course    Course @relation(fields: [course_id], references: [course_id])
  skill     Skill  @relation(fields: [skill_id], references: [skill_id])

  @@unique([course_id, skill_id])
}

model AuditLog {
  id              BigInt   @id @default(autoincrement())

  user_id         BigInt?
  email           String?  @db.VarChar(255) 

  action          String   @db.VarChar(50)
  entity_type     String?  @db.VarChar(50)
  entity_id       String?

  endpoint        String   @db.VarChar(255)
  method          String   @db.VarChar(10)

  request_payload Json?
  response_payload Json?

  status_code     Int?
  success         Boolean  @default(true)

  error_message   String?

  ip_address      String?  @db.VarChar(50)
  user_agent      String?

  created_at      DateTime @default(now())

}

model UserDevice {
  id         Int      @id @default(autoincrement())

  user_id    BigInt
  token      String

  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [user_id])

  @@unique([user_id, token])
}

model Notification {
  notification_id Int      @id @default(autoincrement())

  user_id         BigInt
  user            User     @relation(fields: [user_id], references: [user_id])

  title           String
  message         String

  type            String?   @db.VarChar(50) // job, internship, course, hackathon

  is_read         Boolean   @default(false)

  // Optional (very useful for navigation)
  entity_id       Int?      // e.g., job_id / course_id / hackathon_id
  redirect_url    String?   // deep link for frontend navigation

  created_at      DateTime  @default(now())
}

model Interest {
  interest_id Int    @id @default(autoincrement())
  name        String @unique

  userInterests UserInterest[]
  courseInterests CourseInterest[]
}

model UserInterest {
  id           Int @id @default(autoincrement())

  user_id      BigInt
  interest_id  Int

  user         User     @relation(fields: [user_id], references: [user_id])
  interest     Interest @relation(fields: [interest_id], references: [interest_id])

  @@unique([user_id, interest_id])
}

model Achievement {
  achievement_id Int    @id @default(autoincrement())

  title          String @db.VarChar(255)
  description    String?

  icon           String? // optional UI icon

  userAchievements UserAchievement[]
}

model UserAchievement {
  id              Int @id @default(autoincrement())

  user_id         BigInt
  achievement_id  Int

  achieved_at     DateTime @default(now())

  user            User        @relation(fields: [user_id], references: [user_id])
  achievement     Achievement @relation(fields: [achievement_id], references: [achievement_id])

  @@unique([user_id, achievement_id])
}

model CourseInterest {
  id          Int      @id @default(autoincrement())

  course_id   Int
  interest_id Int

  course      Course   @relation(fields: [course_id], references: [course_id], onDelete: Cascade)
  interest    Interest @relation(fields: [interest_id], references: [interest_id], onDelete: Cascade)

  @@unique([course_id, interest_id])
}

model SavedCourse {
  saved_id    Int      @id @default(autoincrement())
  user_id     BigInt
  course_id   Int
  saved_at    DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [user_id])
  course      Course   @relation(fields: [course_id], references: [course_id])

  @@unique([user_id, course_id])
}